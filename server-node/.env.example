## IronShield EDR (enterprise)
## Copy to .env and set ALL values.

# Server
PORT=3000
NODE_ENV=production
TRUST_PROXY=true
ENFORCE_TLS_IN_PRODUCTION=true
ENFORCE_AGENT_MTLS_IN_PRODUCTION=true

# TLS / mTLS
TLS_ENABLED=true
TLS_KEY_PATH=
TLS_CERT_PATH=
TLS_CA_PATH=
AGENT_MTLS_REQUIRED=true

# CORS (comma-separated allowlist)
CORS_ORIGINS=https://edr.example.com

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=edr_user
DB_PASSWORD=replace-me
DB_NAME=edr_platform

# Auth
JWT_SECRET=replace-me-with-a-strong-secret
JWT_EXPIRES_IN=24h
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCK_MINUTES=15
AUTH_ENFORCE_MFA_ALL_ADMINS=true
AUTH_REQUIRE_MFA_LOCAL_LOGIN=true
# session invalidation on-demand (JWT includes session_version)

# SSO federation
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPE=openid profile email
OIDC_ACR_VALUES=

# SAML proxy-mode federation (through trusted reverse proxy / IdP gateway)
SAML_ENABLED=false
SAML_TRUSTED_PROXY_SECRET=
SAML_TRUSTED_HEADER_USER=x-sso-user
SAML_TRUSTED_HEADER_EMAIL=x-sso-email
SAML_TRUSTED_HEADER_NAMEID=x-sso-nameid

# Agent enrollment
AGENT_REGISTRATION_TOKEN=replace-me-with-a-strong-token

# XDR ingest (3rd party sources)
XDR_INGEST_KEY=replace-me-with-a-strong-ingest-key

# Metrics (optional; if METRICS_TOKEN is set, /metrics requires it)
METRICS_ENABLED=true
METRICS_TOKEN=

# Kafka (optional)
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ironshield-edr
KAFKA_GROUP_ID=ironshield-workers

# SIEM export reliability (optional)
SIEM_NDJSON_PATH=
SIEM_WEBHOOK_URL=
SIEM_WEBHOOK_SECRET=
SIEM_FAILED_NDJSON_PATH=

# Optional immutable audit archive (append-only NDJSON on hardened storage)
AUDIT_ARCHIVE_PATH=
AUDIT_ARCHIVE_HMAC_KEY=

# Ingest idempotency retention
AGENT_EVENT_IDEMPOTENCY_RETENTION_DAYS=7

